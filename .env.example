# Salin file ini menjadi ".env" lalu isi dengan nilai asli kamu.
# JANGAN commit file ".env" (berisi kredensial asli) ke Git — sudah masuk .gitignore.

# API key data odds pertandingan — daftar gratis di https://the-odds-api.com
ODDS_API_KEY=

# API key Stake.com (x-access-token dari akun kamu)
STAKE_API_KEY=

# Kredensial bot Telegram — token dari @BotFather, chat_id dari @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
